{
  "name": "esapai-listen",
  "productName": "Omni Listen",
  "version": "1.0.0",
  "private": true,
  "main": "dist-electron/main/index.js",
  "description": "Background Listening Agent Desktop App",
  "author": "Omni Listen Team",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "dev:electron": "concurrently \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:3000 && tsc -p tsconfig.electron.json && cross-env ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "build:main": "tsc -p tsconfig.electron.json",
    "dist": "cross-env ELECTRON_BUILD=true NEXT_PUBLIC_API_URL=https://esaplistenweb.onrender.com next build && npm run build:main && electron-builder",
    "dist:local": "cross-env ELECTRON_BUILD=true NEXT_PUBLIC_API_URL=http://localhost:8000 next build && npm run build:main && electron-builder",
    "boneyard:build": "npx boneyard-js build http://localhost:3000"
  },
  "build": {
    "appId": "com.esap.listen",
    "files": [
      "out/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "icon": "public/logo.png",
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "public/logo.png",
      "target": "nsis"
    },
    "protocols": [
      {
        "name": "Omni Listen Protocol",
        "schemes": [
          "esapai-listen"
        ]
      }
    ]
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tanstack/react-query": "^5.51.1",
    "axios": "^1.7.2",
    "boneyard-js": "^1.6.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^8.1.0",
    "framer-motion": "^12.23.25",
    "geist": "^1.7.0",
    "html2pdf.js": "^0.12.1",
    "lucide-react": "^0.408.0",
    "next": "^16.2.2",
    "next-auth": "^4.24.7",
    "next-themes": "^0.4.6",
    "node-record-lpcm16": "^1.0.1",
    "onnxruntime-node": "^1.16.0",
    "react": "^18.3.1",
    "react-big-calendar": "^1.19.4",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.1",
    "react-hot-toast": "^2.6.0",
    "socket.io-client": "^4.7.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.14.10",
    "@types/react": "^19.2.14",
    "@types/react-big-calendar": "^1.8.9",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.2",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "wait-on": "^7.2.0"
  }
}
